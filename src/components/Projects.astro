---
const projects = [
    {
        name: 'Gazebo Simulations',
        description:
            'ROS 2 Gazebo simulation environment for TrickFire Robotics\u2019 Mars rover. Enables the software team to iterate without physical hardware using Gazebo Fortress, RViz, URDF, and Docker.',
        tags: ['Python', 'ROS 2', 'Gazebo', 'Docker', 'URDF'],
        url: 'https://github.com/matejstastny/gazebo-simulations',
        highlight: true,
        badge: 'Team project',
        icon: 'rover',
    },
    {
        name: 'Flaggi',
        description:
            'A multiplayer capture-the-flag game built entirely from scratch in Java \u2014 no game engine, no frameworks, just raw graphics and networking.',
        tags: ['Java', 'Networking', 'Graphics', 'Game Dev'],
        url: 'https://github.com/matejstastny/flaggi',
        highlight: false,
        badge: 'Solo project',
        icon: 'flag',
    },
    {
        name: 'Azalea',
        description:
            'A minimal CLI tool for managing Minecraft Modrinth and Fabric modpacks. Install, update, and sync mods from the terminal without fiddling with launchers.',
        tags: ['Python', 'CLI', 'Modrinth API'],
        url: 'https://github.com/matejstastny/azalea',
        highlight: false,
        badge: 'Solo project',
        icon: 'flower',
    },
];
---

<section id="projects">
    <div class="container">
        <span class="section-label">// projects</span>
        <h2 class="section-title">Things I've built</h2>

        <div class="project-grid">
            {
                projects.map((p) => (
                    <a
                        href={p.url}
                        target="_blank"
                        rel="noopener"
                        class:list={['project-card', { 'project-card--featured': p.highlight }]}
                    >
                        <div class="card-header">
                            <div class="card-header-left">
                                <span class="card-icon">
                                    {p.icon === 'rover' && (
                                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="4" y="6" width="16" height="8" rx="2"></rect>
                                            <circle cx="7" cy="18" r="2"></circle>
                                            <circle cx="17" cy="18" r="2"></circle>
                                            <path d="M7 16v-2"></path>
                                            <path d="M17 16v-2"></path>
                                            <path d="M12 6V3"></path>
                                            <path d="M9 3h6"></path>
                                        </svg>
                                    )}
                                    {p.icon === 'flag' && (
                                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path>
                                            <line x1="4" y1="22" x2="4" y2="15"></line>
                                        </svg>
                                    )}
                                    {p.icon === 'flower' && (
                                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M12 7.5a4.5 4.5 0 1 1 4.5 4.5M12 7.5A4.5 4.5 0 1 0 7.5 12M12 7.5V9m-4.5 3a4.5 4.5 0 1 0 4.5 4.5M7.5 12H9m7.5 0a4.5 4.5 0 1 1-4.5 4.5m4.5-4.5H15m-3 4.5V15"></path>
                                            <circle cx="12" cy="12" r="3"></circle>
                                            <path d="m8 16 1.5-1.5"></path>
                                            <path d="M14.5 9.5 16 8"></path>
                                            <path d="m8 8 1.5 1.5"></path>
                                            <path d="M14.5 14.5 16 16"></path>
                                        </svg>
                                    )}
                                </span>
                                <span class="card-badge">{p.badge}</span>
                            </div>
                            <svg
                                class="card-arrow"
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <>
                                    <path d="M7 17L17 7" />
                                    <path d="M7 7h10v10" />
                                </>
                            </svg>
                        </div>
                        <h3 class="card-title">{p.name}</h3>
                        <p class="card-desc">{p.description}</p>
                        <div class="card-tags">
                            {p.tags.map((t) => (
                                <span class="tag">{t}</span>
                            ))}
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</section>

<style>
    .project-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 1.5rem;
    }

    /* ── Card ── */
    .project-card {
        position: relative;
        display: flex;
        flex-direction: column;
        padding: 2rem;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 16px;
        color: var(--cream);
        transition: all 0.4s ease;
        overflow: hidden;
    }

    .project-card::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 16px;
        opacity: 0;
        background: radial-gradient(
            600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
            rgba(168, 85, 247, 0.06),
            transparent 40%
        );
        transition: opacity 0.4s ease;
        pointer-events: none;
    }

    .project-card:hover::before {
        opacity: 1;
    }

    .project-card:hover {
        border-color: var(--border-hover);
        box-shadow: 0 4px 40px rgba(168, 85, 247, 0.08);
        transform: translateY(-4px);
        color: var(--cream);
    }

    .project-card--featured {
        border-color: rgba(168, 85, 247, 0.12);
        background:
            linear-gradient(135deg, rgba(168, 85, 247, 0.04) 0%, rgba(236, 72, 153, 0.02) 50%, transparent 100%),
            var(--bg-card);
    }

    /* ── Card internals ── */
    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .card-header-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .card-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: rgba(168, 85, 247, 0.1);
        color: var(--violet);
        transition: all 0.3s ease;
    }

    .project-card:hover .card-icon {
        background: rgba(168, 85, 247, 0.18);
        box-shadow: 0 0 16px rgba(168, 85, 247, 0.15);
    }

    .card-badge {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--pink);
        padding: 0.3rem 0.7rem;
        background: rgba(236, 72, 153, 0.08);
        border-radius: 6px;
    }

    .card-arrow {
        color: var(--text-muted);
        transition: all 0.3s ease;
    }

    .project-card:hover .card-arrow {
        color: var(--violet);
        transform: translate(2px, -2px);
    }

    .card-title {
        font-size: 1.35rem;
        font-style: italic;
        margin-bottom: 0.75rem;
    }

    .card-desc {
        font-size: 0.93rem;
        color: var(--text-secondary);
        flex: 1;
        margin-bottom: 1.5rem;
    }

    .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .tag {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.04em;
        padding: 0.3rem 0.65rem;
        border-radius: 6px;
        background: var(--bg-secondary);
        color: var(--text-muted);
        border: 1px solid var(--border);
        transition: all 0.25s ease;
    }

    .project-card:hover .tag {
        border-color: rgba(168, 85, 247, 0.12);
        color: var(--text-secondary);
    }

    @media (max-width: 768px) {
        .project-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<script>
    document.querySelectorAll('.project-card').forEach((card) => {
        card.addEventListener('mousemove', (e) => {
            const rect = (e.currentTarget as HTMLElement).getBoundingClientRect();
            const x = ((e.clientX - rect.left) / rect.width) * 100;
            const y = ((e.clientY - rect.top) / rect.height) * 100;
            (e.currentTarget as HTMLElement).style.setProperty('--mouse-x', `${x}%`);
            (e.currentTarget as HTMLElement).style.setProperty('--mouse-y', `${y}%`);
        });
    });
</script>
