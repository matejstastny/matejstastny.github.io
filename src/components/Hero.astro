---

---

<section id="hero">
    <div class="hero-ambient hero-ambient--left"></div>
    <div class="hero-ambient hero-ambient--right"></div>
    <div class="hero-ambient hero-ambient--center"></div>

    <div class="container hero-grid">
        <div class="hero-content">
            <p class="hero-greeting fade-in">Hey there, I'm</p>
            <h1 class="hero-name fade-in delay-1">
                Matej&nbsp;<span class="glow">Stastny</span>
            </h1>
            <p class="hero-tagline fade-in delay-2">
                Computer Engineering student, simulation lead, and builder of things that move,
                click, and occasionally explode.
            </p>
            <div class="hero-cta fade-in delay-3">
                <a href="#projects" class="btn btn--primary">See my work</a>
                <a href="#contact" class="btn btn--ghost">Get in touch</a>
            </div>
        </div>

        <div class="hero-visual fade-in delay-2">
            <div class="photo-frame">
                <img
                    src="/matej.jpg"
                    alt="Matej Stastny"
                    width="340"
                    height="340"
                    class="hero-photo"
                />
                <div class="photo-glow"></div>
                <div class="photo-ring"></div>
            </div>
        </div>
    </div>

    <div class="scroll-hint fade-in delay-5">
        <span>scroll</span>
        <div class="scroll-line"></div>
    </div>
</section>

<style>
    /* ── Section ── */
    #hero {
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding-top: 5rem;
        position: relative;
        overflow: hidden;
    }

    /* ── Ambient glows ── */
    .hero-ambient {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
    }

    .hero-ambient--left {
        top: 10%;
        left: -10%;
        width: 550px;
        height: 550px;
        background: radial-gradient(circle, rgba(168, 85, 247, 0.08) 0%, transparent 70%);
        animation: breathe 8s ease-in-out infinite;
    }

    .hero-ambient--right {
        bottom: 5%;
        right: -8%;
        width: 450px;
        height: 450px;
        background: radial-gradient(circle, rgba(236, 72, 153, 0.06) 0%, transparent 70%);
        animation: breathe 10s ease-in-out infinite 2s;
    }

    .hero-ambient--center {
        top: 40%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 700px;
        height: 700px;
        background: radial-gradient(circle, rgba(124, 58, 237, 0.04) 0%, transparent 60%);
        animation: breathe 12s ease-in-out infinite 4s;
    }

    /* ── Grid ── */
    .hero-grid {
        display: flex;
        align-items: center;
        gap: 4rem;
        position: relative;
        z-index: 1;
    }

    .hero-content {
        flex: 1;
        min-width: 0;
    }

    /* ── Text ── */
    .hero-greeting {
        font-family: var(--font-mono);
        font-size: 0.88rem;
        color: var(--pink);
        letter-spacing: 0.05em;
        margin-bottom: 0.75rem;
    }

    .hero-name {
        font-size: clamp(2.8rem, 7vw, 4.5rem);
        font-weight: 400;
        font-style: italic;
        line-height: 1.08;
        margin-bottom: 1.5rem;
        letter-spacing: -0.01em;
    }

    .hero-tagline {
        font-size: 1.05rem;
        color: var(--text-secondary);
        max-width: 520px;
        margin-bottom: 2.5rem;
    }

    /* ── CTA buttons ── */
    .hero-cta {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        padding: 0.78rem 2rem;
        font-family: var(--font-body);
        font-weight: 500;
        font-size: 0.88rem;
        border-radius: 10px;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .btn--primary {
        background: linear-gradient(135deg, var(--violet), var(--pink));
        color: #fff;
        box-shadow: 0 0 24px rgba(168, 85, 247, 0.25);
    }

    .btn--primary:hover {
        color: #fff;
        box-shadow:
            0 0 40px rgba(168, 85, 247, 0.4),
            0 0 80px rgba(236, 72, 153, 0.15);
        transform: translateY(-2px);
    }

    .btn--ghost {
        border: 1px solid var(--border-hover);
        color: var(--cream);
        background: transparent;
    }

    .btn--ghost:hover {
        border-color: var(--violet);
        color: var(--violet-light);
        background: rgba(168, 85, 247, 0.05);
        transform: translateY(-2px);
    }

    /* ── Photo ── */
    .hero-visual {
        flex-shrink: 0;
    }

    .photo-frame {
        position: relative;
        width: 320px;
        height: 320px;
    }

    .hero-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 24px;
        border: 2px solid rgba(168, 85, 247, 0.25);
        position: relative;
        z-index: 1;
        transition:
            border-color 0.4s ease,
            box-shadow 0.4s ease;
    }

    .photo-frame:hover .hero-photo {
        border-color: rgba(168, 85, 247, 0.5);
        box-shadow: 0 0 40px rgba(168, 85, 247, 0.15);
    }

    .photo-glow {
        position: absolute;
        inset: -24px;
        background: radial-gradient(
            circle at 30% 30%,
            rgba(168, 85, 247, 0.12) 0%,
            rgba(236, 72, 153, 0.06) 50%,
            transparent 70%
        );
        border-radius: 40px;
        z-index: 0;
        animation: breathe 6s ease-in-out infinite;
    }

    .photo-ring {
        position: absolute;
        inset: -8px;
        border-radius: 30px;
        border: 1px solid rgba(168, 85, 247, 0.1);
        z-index: 0;
        animation: breathe 8s ease-in-out infinite 1s;
    }

    /* ── Scroll indicator ── */
    .scroll-hint {
        position: absolute;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
    }

    .scroll-hint span {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .scroll-line {
        width: 1px;
        height: 36px;
        background: linear-gradient(to bottom, var(--violet-dim), transparent);
        animation: float 3s ease-in-out infinite;
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
        .hero-grid {
            flex-direction: column-reverse;
            gap: 2.5rem;
            text-align: center;
        }

        .hero-tagline {
            margin-inline: auto;
        }

        .hero-cta {
            justify-content: center;
        }

        .photo-frame {
            width: 220px;
            height: 220px;
        }

        .scroll-hint {
            display: none;
        }
    }
</style>
