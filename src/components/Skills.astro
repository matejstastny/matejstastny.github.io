---
const categories = [
  {
    name: 'Languages',
    icon: '🌎',
    items: ['Java', 'Python', 'Bash', 'C#'],
  },
  {
    name: 'Game Engines',
    icon: '🎮',
    items: ['Godot', 'GameMaker', 'Unity', 'libGDX'],
  },
  {
    name: 'Robotics & DevOps',
    icon: '🦾',
    items: ['ROS 2', 'Gazebo', 'RViz', 'Docker', 'URDF'],
  },
  {
    name: 'Tools',
    icon: '🛠️',
    items: ['Git', 'GitHub', 'VS Code', 'Illustrator', 'Microsoft Suite'],
  },
];
---

<section id="skills">
  <div class="container">
    <span class="section-label">// skills</span>
    <h2 class="section-title">What I work with</h2>

    <div class="skills-grid">
      {categories.map((cat) => (
        <div class="skill-group">
          <div class="skill-group-header">
            <span class="skill-icon">{cat.icon}</span>
            <h3 class="skill-category">{cat.name}</h3>
          </div>
          <div class="skill-pills">
            {cat.items.map((item) => (
              <span class="pill">{item}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .skill-group {
    padding: 1.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    transition: all 0.35s ease;
  }

  .skill-group:hover {
    border-color: var(--border-hover);
    box-shadow: 0 0 24px rgba(232, 168, 76, 0.05);
  }

  .skill-group-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.1rem;
  }

  .skill-icon {
    font-size: 1.2rem;
    line-height: 1;
  }

  .skill-category {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .skill-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .pill {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.03em;
    padding: 0.38rem 0.8rem;
    border-radius: 8px;
    background: var(--bg-secondary);
    color: var(--text-secondary);
    border: 1px solid var(--border);
    transition: all 0.25s ease;
  }

  .skill-group:hover .pill {
    border-color: rgba(232, 168, 76, 0.1);
  }

  .pill:hover {
    color: var(--amber);
    border-color: var(--border-hover) !important;
    background: rgba(232, 168, 76, 0.06);
  }

  @media (max-width: 768px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
